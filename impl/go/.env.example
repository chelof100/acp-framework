# ACP Reference Server — environment variables
# Copy to .env and fill in the values before running docker compose up

# ─── Required ─────────────────────────────────────────────────────────────────

# Ed25519 public key of the institution that issues capability tokens.
# base64url-encoded, no padding.
#
# For development/testing, use the RFC 8037 Test Key A:
#   ACP_INSTITUTION_PUBLIC_KEY=cA4s58S2dEJ-qye6EpJaJKKaVfvPT8mAQf97Vo8TInk
#
# To generate your own key with the Python SDK:
#   cd ../python
#   python -c "
#   from acp.identity import AgentIdentity; import base64
#   a = AgentIdentity.generate()
#   print(base64.urlsafe_b64encode(a.public_key_bytes).rstrip(b'=').decode())
#   "
ACP_INSTITUTION_PUBLIC_KEY=cA4s58S2dEJ-qye6EpJaJKKaVfvPT8mAQf97Vo8TInk

# ─── Optional ─────────────────────────────────────────────────────────────────

# Port (default: 8080)
ACP_PORT=8080

# Log level: debug | info | warn | error (default: info)
ACP_LOG_LEVEL=info
